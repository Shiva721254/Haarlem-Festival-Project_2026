DB_HOST=mysql
DB_PORT=3306
DB_NAME=haarlem_festival
DB_USER=haarlem_user
DB_PASS=secret
DB_ROOT_PASS=rootsecret

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Mail. Defaults (in code) target the local MailHog container, so you only
# need to set these to use a real SMTP provider in production.
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_AUTH=false
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=
MAIL_FROM_EMAIL=noreply@haarlemfestival.com
MAIL_FROM_NAME=Haarlem Festival Support

# Stripe (test/sandbox) — set real keys in .env, never commit them
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
APP_URL=http://localhost
